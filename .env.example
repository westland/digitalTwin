# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...            # From platform.openai.com

TAVUS_API_KEY=tvs-...            # From platform.tavus.io → API Keys
TAVUS_REPLICA_ID=                # Your digital twin replica ID (from GET /api/replicas)
TAVUS_PERSONA_ID=                # Set after POST /api/persona (auto-filled by the app)

# ── Identity ──────────────────────────────────────────────────────────────────
PROFESSOR_NAME=Professor Smith   # Your name — appears in the avatar's system prompt

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_URL=http://143.198.228.58 # Your public URL (or https://yourdomain.com)
# Tavus calls this URL for the custom LLM: SERVER_URL/api/llm

# ── Optional ──────────────────────────────────────────────────────────────────
CHROMA_DIR=./data/chroma         # Where ChromaDB persists embeddings
AUTO_CLEAN_NOTES=false           # Set 'true' to auto-clean uploaded notes with GPT-4o-mini
